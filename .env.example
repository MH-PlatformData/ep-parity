# Database connection URIs
# Copy this file to .env and replace with your actual credentials.
# NEVER commit .env to version control.

DB_PRIMARY_URI=postgresql://your_username:your_password@primary-portal-db.qa.internal.marathon-health.com:5432/portal_qa
DB_REPLICATED_URI=postgresql://your_username:your_password@primary-pariveda-db.qa.internal.marathon-health.com:5432/portal_qa
DB_PRODUCTION_URI=postgresql://your_username:your_password@primary-portal-db.prod.internal.marathon-health.com:5432/portal_production

# Optional: Pariveda dev database
# DB_PARIVEDA_DEV_URI=postgresql://your_username:your_password@primary-pariveda-db.dev.internal.marathon-health.com:5432/portal_dev
